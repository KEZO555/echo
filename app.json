{
	"expo": {
		"name": "Spotify (Light)",
		"slug": "spotify-light",
		"version": "2.3.1",
		"orientation": "portrait",
		"scheme": "spotify-light",
		"newArchEnabled": true,
		"android": {
			"backgroundColor": "#000000",
			"package": "com.vandamd.spotifylight"
		},
		"plugins": ["expo-router", "expo-secure-store"],
