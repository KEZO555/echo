{
	"expo": {
		"name": "Spotify (Light)",
		"slug": "spotify-light",
		"version": "1.0.0",
		"orientation": "portrait",
		"scheme": "spotify-light",
		"newArchEnabled": true,
		"android": {
			"backgroundColor": "#000000",
			"edgeToEdgeEnabled": true,
			"package": "com.vandamd.spotify-light"
		},
		"androidNavigationBar": {
			"visible": "immersive",
			"backgroundColor": "#00000000"
		},
		"plugins": ["expo-router", "expo-secure-store", "expo-web-browser"],
		"experiments": {
			"typedRoutes": true
		}
	}
}
